# Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
WEBHOOK_VERIFY_TOKEN=

# ─── WhatsApp Business Cloud ───────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Notifications ─────────────────────────────────────────────────────────────
# Email or Telegram for human handoff alerts (required for MVP)
TEAM_NOTIFICATION_EMAIL=
# Optional: WhatsApp number for management weekly report
MANAGEMENT_WHATSAPP_NUMBER=

# ─── Optional: Google Sheets (MVP dashboard) ───────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ─── Social Media (upload-post.com) ──────────────────────────────────────────
UPLOAD_POST_API_KEY=
