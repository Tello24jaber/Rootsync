# Environment Variables
# Copy this file to .env and fill in values. Never commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://user:password@host:5432/rootsync

# ─── WhatsApp Business Cloud ───────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=
# ─── n8n ───────────────────────────────────────────────────────────────────────


# ─── Notifications ─────────────────────────────────────────────────────────────
# WhatsApp number or email to notify team on human handoff
TEAM_NOTIFICATION_PHONE=
TEAM_NOTIFICATION_EMAIL=

# ─── Optional: Google Sheets (MVP dashboard) ───────────────────────────────────
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
